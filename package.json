{
  "name": "mem-lang",
  "displayName": "Mem Lang",
  "description": "MemLang 语法高亮与智能补全",
  "version": "1.3.2",
  "publisher": "LozinLilis",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/LozinLilis/vscode-memlang"
  },
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "memlang",
        "aliases": [
          "MemLang",
          "memlang"
        ],
        "extensions": [
          ".mem"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "memlang",
        "scopeName": "source.memlang",
        "path": "./syntaxes/memlang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "memlang",
        "path": "./snippets/memlang.json"
      }
    ],
    "iconThemes": [
      {
        "id": "memlang-icons",
        "label": "MemLang Icons",
        "path": "./memlang-icon-theme.json"
      }
    ]
  }
}
